{
  "manifest_version": 3,
  "name": "My Browser Extension",
  "description": "A brief description of what the extension does.",
  "version": "1.0.0",

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-32.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },

  "background": {
    "service_worker": "scripts/background.js"
  },

  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],

  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],

  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },

  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": [
        "scripts/popup.js"
            ],
      "css": [
        "styles/messages.css",
        "styles/main.css",
        "styles/logs.css",
        "styles/input.css",
        "styles/header.css",
        "styles/global.css",
        "styles/content.css",
        "styles/colors.css",
        "styles/analysis.css",
        "styles/modal.css",
        "styles/navigation_sidebar.css",
        "styles/page-sections.css",
        "styles/reports.css",
        "styles/settings-items.css",
        "styles/switch-toggle.css",
        "styles/tests.css"
      ]
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
